# 复制为 .env 后修改以下必填项
# cp .env.example .env

# 对外端口（宿主机）
HOST_PORT=5173

# 数据库密码（必填）
POSTGRES_PASSWORD=

# 管理员账号（首次启动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 加密密钥（必填，≥32 字符；丢失后无法解密已存 Key）
# 生成：openssl rand -base64 32
ENCRYPTION_KEY=

# 是否要求搜索 API 带 Token（默认 true）
API_AUTH_REQUIRED=true

# 是否开启 MCP（默认 true）
MCP_ENABLED=true
