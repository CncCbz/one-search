APP_ENV=production
HTTP_ADDR=:8080
POSTGRES_DB=one_search
POSTGRES_USER=one_search
# 必填：生产环境请设置强 PostgreSQL 密码
POSTGRES_PASSWORD=
DATABASE_URL=postgres://one_search:CHANGE_ME@localhost:15432/one_search?sslmode=disable
RUN_MIGRATIONS=true
MIGRATIONS_DIR=migrations
ADMIN_USERNAME=admin
# 首次创建管理员时必填；生产环境不要使用默认/弱密码
ADMIN_PASSWORD=
# 必填：至少 32 字符的随机字符串，丢失后无法解密已保存密钥
ENCRYPTION_KEY=
API_AUTH_REQUIRED=true
# 是否开放 MCP HTTP JSON-RPC 接口；默认关闭
MCP_ENABLED=false
# MCP 接口路径。启用后默认挂载 POST/GET /mcp
MCP_PATH=/mcp
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
REQUEST_BODY_LIMIT_BYTES=1048576
SERVER_READ_HEADER_TIMEOUT_MS=10000
SERVER_READ_TIMEOUT_MS=30000
SERVER_WRITE_TIMEOUT_MS=30000
SERVER_IDLE_TIMEOUT_MS=60000
ADMIN_SESSION_TTL_HOURS=24
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MS=300000
ADMIN_LOGIN_LOCKOUT_MS=900000
VITE_API_BASE=
